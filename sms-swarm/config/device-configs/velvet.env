# velvet — primary SMS gateway + mobile agent
# Run via Termux on LG Velvet: python swarm-agent.py

DEVICE_NAME=velvet
DEVICE_ROLE=primary SMS gateway and mobile agent — lightweight task routing and notifications

# Groq is fastest for mobile (low latency, free tier)
LLM_BACKEND=groq
API_KEY=YOUR_GROQ_API_KEY

# Velvet IS the SMS gateway — it sends to itself (loopback)
SMS_GATEWAY_URL=http://localhost:8080
SMS_GATEWAY_USER=FILL_FROM_SMSGATE_APP
SMS_GATEWAY_PASS=FILL_FROM_SMSGATE_APP
ALLOWED_SENDERS=+1YOUR_PHONE_NUMBER
PORT=5001
