# shitbox-jr — compute worker
# Copy to /mnt/trading/sms-swarm/.env on shitbox-jr

DEVICE_NAME=shitbox-jr
DEVICE_ROLE=compute worker — code execution, backtesting, data analysis, local Qwen inference

# Use local Ollama (no API key needed)
LLM_BACKEND=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen-swarm

# SMS gateway — velvet is the primary gateway
SMS_GATEWAY_URL=http://100.VELVET_TAILSCALE_IP:8080
SMS_GATEWAY_USER=FILL_FROM_SMSGATE_APP
SMS_GATEWAY_PASS=FILL_FROM_SMSGATE_APP

# Only accept SMS from your own numbers
ALLOWED_SENDERS=+1YOUR_PHONE_NUMBER

PORT=5000
