# potato — high-performance Windows node (DESKTOP-RBCUO93)
# i7-9750H 6-core, 32GB RAM — best inference node in the fleet
# Run in PowerShell or WSL: python swarm-agent.py

DEVICE_NAME=potato
DEVICE_ROLE=high-performance inference node — heavy compute, large model hosting, GPU acceleration (if GTX 1650/1660 Ti present)

# If GPU confirmed: switch to ollama with a 13B model
# If CPU only: groq is better (faster than local CPU inference at 13B)
LLM_BACKEND=groq
API_KEY=YOUR_GROQ_API_KEY

# Once GPU is confirmed, switch to:
# LLM_BACKEND=ollama
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:14b

SMS_GATEWAY_URL=http://100.VELVET_TAILSCALE_IP:8080
SMS_GATEWAY_USER=FILL_FROM_SMSGATE_APP
SMS_GATEWAY_PASS=FILL_FROM_SMSGATE_APP
ALLOWED_SENDERS=+1YOUR_PHONE_NUMBER
PORT=5003
