# sha-dynasty — credential vault + backup SMS gateway
# Run via Termux on Samsung S9

DEVICE_NAME=sha-dynasty
DEVICE_ROLE=credential vault and backup SMS gateway — secure storage, emergency fallback

LLM_BACKEND=gemini
API_KEY=YOUR_GEMINI_API_KEY

SMS_GATEWAY_URL=http://localhost:8080
SMS_GATEWAY_USER=FILL_FROM_SMSGATE_APP
SMS_GATEWAY_PASS=FILL_FROM_SMSGATE_APP
ALLOWED_SENDERS=+1YOUR_PHONE_NUMBER
PORT=5001
