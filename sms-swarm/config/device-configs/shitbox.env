# shitbox — primary orchestrator
# Copy to ~/sms-swarm/.env on shitbox

DEVICE_NAME=shitbox
DEVICE_ROLE=primary orchestrator — task routing, Freqtrade live trading, Claude Haiku inference

# DeepSeek is the best reasoning model for orchestration decisions
LLM_BACKEND=deepseek
API_KEY=YOUR_DEEPSEEK_API_KEY

SMS_GATEWAY_URL=http://100.VELVET_TAILSCALE_IP:8080
SMS_GATEWAY_USER=FILL_FROM_SMSGATE_APP
SMS_GATEWAY_PASS=FILL_FROM_SMSGATE_APP
ALLOWED_SENDERS=+1YOUR_PHONE_NUMBER
PORT=5000
