# SHA-Dynasty SMS Swarm — environment variables
# Copy this to .env and fill in your values. Never commit .env to git.

# SMSGate credentials (shown on the app home screen on velvet/sha-dynasty)
SMS_GATEWAY_URL=http://100.VELVET_TAILSCALE_IP:8080
SMS_GATEWAY_USER=username_from_app
SMS_GATEWAY_PASS=password_from_app

# Ollama (running locally on shitbox-jr)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen-swarm

# Comma-separated list of phone numbers allowed to send commands via SMS
# Leave empty to allow all senders (not recommended)
ALLOWED_SENDERS=+15551234567,+15559876543

# Port for the webhook receiver
PORT=5000
